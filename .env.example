# ─────────────────────────────────────────────────────────────
#  ApexTrade — Environment Variables Template
#  Copy this file to `.env` in the repo root (consumed by Docker
#  Compose) and create app-level .env files as noted below.
# ─────────────────────────────────────────────────────────────

# ===== Shared / Infra =====
NODE_ENV=development

# ===== PostgreSQL =====
POSTGRES_USER=apex
POSTGRES_PASSWORD=change_me_super_secret
POSTGRES_DB=apextrade
POSTGRES_PORT=5432
# Full connection string consumed by Prisma (apps/api/.env)
DATABASE_URL=postgresql://apex:change_me_super_secret@localhost:5432/apextrade?schema=public

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ===== Backend (apps/api) =====
API_PORT=4000
API_GLOBAL_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# JWT — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_REFRESH_TTL=604800

# 2FA issuer name shown in authenticator apps
TOTP_ISSUER=ApexTrade

# Rate limiting (requests per window)
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# SMTP — for email verification & password reset.
# In dev, leave SMTP_HOST empty to log emails to the console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ApexTrade <no-reply@apextrade.local>"

# Seed super-admin account (created by `npm run db:seed`)
SEED_SUPERADMIN_EMAIL=admin@apextrade.local
SEED_SUPERADMIN_PASSWORD=Admin123!Change

# ===== Frontend (apps/web) =====
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_SITE_NAME=ApexTrade
