# Backend env (apps/api/.env). Prisma reads DATABASE_URL from here.
NODE_ENV=development
API_PORT=4000
API_GLOBAL_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://apex:change_me_super_secret@localhost:5432/apextrade?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_ACCESS_SECRET=replace_with_long_random_access_secret_min_24_chars
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret_min_24_chars
JWT_REFRESH_TTL=604800

TOTP_ISSUER=ApexTrade
THROTTLE_TTL=60
THROTTLE_LIMIT=120

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ApexTrade <no-reply@apextrade.local>"

SEED_SUPERADMIN_EMAIL=admin@apextrade.local
SEED_SUPERADMIN_PASSWORD=Admin123!Change
